{
  "expo": {
    "name": "RKV Consulting",
    "slug": "rkv-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rkv",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.rkvconsulting.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.rkvconsulting.app",
      "adaptiveIcon": { "backgroundColor": "#0A0A0F", "foregroundImage": "./assets/adaptive-icon.png" }
    },
    "plugins": ["expo-router", "react-native-reanimated/plugin"],
    "experiments": { "typedRoutes": true }
  }
}
