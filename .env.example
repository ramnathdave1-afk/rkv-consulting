# Copy to .env.local for local dev. For Vercel, add these in Project → Settings → Environment Variables.

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (REQUIRED for billing) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_ANNUAL=price_...

# ── AI (REQUIRED for leasing agent, maintenance triage, chat) ────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (REQUIRED for SMS tenant/prospect communications) ─────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com  # Base URL for Twilio webhook callbacks (no trailing slash)

# ── Integration Credential Encryption ────────────────────────────────────────
INTEGRATION_ENCRYPTION_KEY=  # 32-byte hex string. Generate with: openssl rand -hex 32

# ── Resend (REQUIRED for email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Cron / Automation ────────────────────────────────────────────────────────
CRON_SECRET=  # Secret for authenticating Vercel Cron jobs (minimum 16 characters)

# ── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000
