# Copy to .env.local for local dev. For Vercel, add these in Project → Settings → Environment Variables.

# Required for Deal Feed Zillow refresh (subscribe to "Zillow Real Estate API" by Collector on RapidAPI)
RAPIDAPI_KEY=
# Optional: only if your Zillow API uses a different host (check Code Snippets for X-RapidAPI-Host)
# RAPIDAPI_ZILLOW_HOST=zillow-real-estate-api-by-collector.p.rapidapi.com

# Optional: Market Intelligence BLS labor data (free at bls.gov/developers)
BLS_API_KEY=
