# Copy to .env.local for local dev. For Vercel, add these in Project → Settings → Environment Variables.

# Deal Feed Zillow refresh (Zillow Real Estate API on RapidAPI — host: zillow-real-estate-api.p.rapidapi.com)
RAPIDAPI_KEY=
# Optional: override host if using a different Zillow API
# RAPIDAPI_ZILLOW_HOST=zillow-real-estate-api.p.rapidapi.com
# Optional: for zillow-real-estate-api only — agent screen name for /v1/agents/{screen_name}/listings
# RAPIDAPI_ZILLOW_AGENT=

# Optional: Market Intelligence BLS labor data (free at bls.gov/developers)
BLS_API_KEY=
