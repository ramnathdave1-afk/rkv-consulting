# Copy to .env.local for local dev. For Vercel, add these in Project → Settings → Environment Variables.

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (REQUIRED for billing) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_ANNUAL=price_...

# ── AI (REQUIRED for leasing agent, maintenance triage, chat) ────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (REQUIRED for SMS tenant/prospect communications) ─────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com  # Base URL for Twilio webhook callbacks (no trailing slash)

# ── Integration Credential Encryption ────────────────────────────────────────
INTEGRATION_ENCRYPTION_KEY=  # 32-byte hex string. Generate with: openssl rand -hex 32

# ── Resend (REQUIRED for email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Cron / Automation ────────────────────────────────────────────────────────
CRON_SECRET=  # Secret for authenticating Vercel Cron jobs (minimum 16 characters)

# ── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000

# ── Outreach System (VPS PostgreSQL) ────────────────────────────────────────
OUTREACH_DB_HOST=31.97.149.47
OUTREACH_DB_PORT=5432
OUTREACH_DB_NAME=outreach
OUTREACH_DB_USER=outreach
OUTREACH_DB_PASSWORD=your-db-password
OUTREACH_DB_SSL=false

# ── Outreach APIs ───────────────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_...
OUTREACH_API_SECRET=  # Secret n8n uses to authenticate calls to Next.js API routes
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_WEBHOOK_SECRET=  # Secret for n8n webhook authentication

# ── Google APIs (Gmail + Calendar for outreach) ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Real estate comps + AVM (acquisitions module) ──────────────────────────
# RentCast API key. Used by the Acquisitions deal scorer to pull real sale
# comps, rent comps, and ZIP-level market data so Claude scores against
# ground truth instead of fabricating numbers. Per-org keys set via
# Settings → Integrations override this. https://developers.rentcast.io/
RENTCAST_API_KEY=

# ── Sentry monitoring (OPTIONAL — error tracking is no-op when DSN is unset) ─
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
