# Copy to .env.local for local dev. For Vercel, add these in Project → Settings → Environment Variables.

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (REQUIRED for billing) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Price IDs (from Stripe Dashboard → Products → Prices)
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_ANNUAL=price_...

# ── AI (REQUIRED for ATLAS assistant, market brief, listing generator) ───────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (REQUIRED for SMS/voice agents) ───────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1...

# ── Resend (REQUIRED for email agents) ────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Market Intelligence ──────────────────────────────────────────────────────
# FRED API (free at fred.stlouisfed.org) — powers Live Market Pulse, interest rates, economic indicators
FRED_API_KEY=
# Rentcast API — powers per-market data, heat maps, deal benchmarks
RENTCAST_API_KEY=
# BLS API (free at bls.gov/developers) — powers labor/employment data
BLS_API_KEY=

# ── Deal Feed ────────────────────────────────────────────────────────────────
# RapidAPI (Zillow Real Estate API) — powers deal feed refresh
RAPIDAPI_KEY=
# ATTOM API — alternative property data for deal feed
ATTOM_API_KEY=

# ── Cron / Autopilot ────────────────────────────────────────────────────────
# Secret for authenticating Vercel Cron jobs (minimum 16 characters)
CRON_SECRET=

# ── App URL ────────────────────────────────────────────────────────────────
# Base URL for links in emails, Stripe redirects, screening application links
NEXT_PUBLIC_URL=http://localhost:3000

# ── Optional ─────────────────────────────────────────────────────────────────
# ElevenLabs — powers AI voice agent
ELEVENLABS_API_KEY=
# Override default RapidAPI Zillow host
# RAPIDAPI_ZILLOW_HOST=zillow-real-estate-api.p.rapidapi.com
# Zillow agent screen name for listings
# RAPIDAPI_ZILLOW_AGENT=
